# KIMS Web environment example
# Copy this file to apps/web/.env.local for local development.
# Never commit apps/web/.env.local or real secrets.

# ---------------------------------------------------------------------------
# Local development: apps/web/.env.local
# ---------------------------------------------------------------------------

# Local API server. The Next.js rewrite proxies /api/v1/* to this URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional analytics and monitoring.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# Optional Sentry upload config for builds.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Vercel production/preview: kims-web project
# Add these in Vercel Dashboard -> kims-web -> Settings -> Environment Variables.
# Frontend variables are exposed to the browser when prefixed with NEXT_PUBLIC_.
# Do not put backend secrets such as DATABASE_URL, JWT secrets, or BREVO_API_KEY here.
# ---------------------------------------------------------------------------

# Required
# NEXT_PUBLIC_API_BASE_URL=https://kims-api.vercel.app

# Optional
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=<umami-website-id>
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://<your-umami-domain>/script.js
# NEXT_PUBLIC_SENTRY_DSN=<frontend-sentry-dsn>
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# Optional Sentry source map upload config
# SENTRY_ORG=<sentry-org>
# SENTRY_PROJECT=<sentry-project>
# SENTRY_AUTH_TOKEN=<sentry-auth-token>
