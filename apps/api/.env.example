# KIMS API environment example
# Copy this file to apps/api/.env for local development.
# Never commit apps/api/.env or real secrets.

# ---------------------------------------------------------------------------
# Local development: apps/api/.env
# ---------------------------------------------------------------------------

APP_ENV=development
HTTP_ADDR=:8080
PORT=8080
WEB_ORIGIN=http://localhost:3000
# Comma-separated frontend origins allowed to call the API from browsers.
# WEB_ORIGINS overrides/adds to WEB_ORIGIN when multiple domains are needed.
WEB_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# In-memory API rate limits per client IP. Windows use Go duration strings.
RATE_LIMIT_API_LIMIT=300
RATE_LIMIT_API_WINDOW=1m
RATE_LIMIT_AUTH_LIMIT=20
RATE_LIMIT_AUTH_WINDOW=1m
RATE_LIMIT_OTP_LIMIT=5
RATE_LIMIT_OTP_WINDOW=10m
RATE_LIMIT_HISTORY_LIMIT=120
RATE_LIMIT_HISTORY_WINDOW=1m
RATE_LIMIT_ADMIN_LIMIT=60
RATE_LIMIT_ADMIN_WINDOW=1m

# Local PostgreSQL example. For Supabase local/prod, replace with your Supabase
# connection string and use sslmode=require.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kims?sslmode=disable

# Use long random strings, 32+ chars minimum.
JWT_ACCESS_SECRET=replace-with-local-access-secret-32-plus-chars
JWT_REFRESH_SECRET=replace-with-local-refresh-secret-32-plus-chars

# Required when tracks use Supabase Storage object paths.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_AUDIO_BUCKET=audio
SUPABASE_COVER_BUCKET=covers

# Optional in local development.
SENTRY_DSN=

# Brevo REST API for forgot-password OTP email.
# BREVO_API_KEY is a Brevo REST API key, not an SMTP key.
BREVO_API_KEY=your-local-brevo-api-key
BREVO_SENDER_NAME=KIMS Music Station
BREVO_SENDER_EMAIL=your-verified-sender-email@example.com
OTP_EXPIRY_MINUTES=30

# Optional local migration controls.
SKIP_MIGRATIONS=false
RUN_MIGRATIONS=false

# ---------------------------------------------------------------------------
# Vercel production/preview: kims-api project
# Add these in Vercel Dashboard -> kims-api -> Settings -> Environment Variables.
# Do not add backend secrets to the kims-web project.
# ---------------------------------------------------------------------------

# Required
# APP_ENV=production
# DATABASE_URL=postgres://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# JWT_ACCESS_SECRET=<random-32-plus-char-secret>
# JWT_REFRESH_SECRET=<random-32-plus-char-secret>
# BREVO_API_KEY=<brevo-rest-api-key-starting-with-xkeysib>
# BREVO_SENDER_NAME=KIMS Music Station
# BREVO_SENDER_EMAIL=hadinurhakim.coding@gmail.com

# Recommended
# SENTRY_DSN=<backend-sentry-dsn>
# SKIP_MIGRATIONS=true
# WEB_ORIGINS=https://kims.example.com,https://www.kims.example.com
# RATE_LIMIT_API_LIMIT=300
# RATE_LIMIT_API_WINDOW=1m
# RATE_LIMIT_AUTH_LIMIT=20
# RATE_LIMIT_AUTH_WINDOW=1m
# RATE_LIMIT_OTP_LIMIT=5
# RATE_LIMIT_OTP_WINDOW=10m
# RATE_LIMIT_HISTORY_LIMIT=120
# RATE_LIMIT_HISTORY_WINDOW=1m
# RATE_LIMIT_ADMIN_LIMIT=60
# RATE_LIMIT_ADMIN_WINDOW=1m

# Required when tracks use Supabase Storage object paths
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_AUDIO_BUCKET=audio
# SUPABASE_COVER_BUCKET=covers

# Usually provided by Vercel; include only if needed
# PORT=8080
# VERCEL=1
